#include <stdio.h>
#include <string.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "driver/uart.h"

#define BUF_SIZE 256

// Buffer para datos recibidos - CAMBIADO 'index' por 'pos'
static char buffer[256];
static int pos_buffer = 0;  // ANTES era 'index'

// Variables globales para estadísticas
char ultimo_id[50] = "";
float ultima_temp = 0;
float ultima_hum = 0;
float ultima_dist = 0;

// Función para buscar texto en el JSON
char* buscar_valor(const char* json, const char* clave) {
    char buscar[50];
    sprintf(buscar, "\"%s\"", clave);
    
    char* pos = strstr(json, buscar);
    if (!pos) return NULL;
    
    pos = strchr(pos, ':');
    if (!pos) return NULL;
    pos++;
    
    while (*pos == ' ') pos++;
    
    return pos;
}

// Extraer string (entre comillas)
void extraer_string(const char* inicio, char* destino) {
    if (*inicio == '"') {
        inicio++;
        int i = 0;
        while (*inicio && *inicio != '"' && i < 48) {
            destino[i++] = *inicio++;
        }
        destino[i] = '\0';
    }
}

// Extraer número
float extraer_numero(const char* inicio) {
    char num[20];
    int i = 0;
    
    while (*inicio && *inicio != ',' && *inicio != '}' && *inicio != ' ' && i < 18) {
        num[i++] = *inicio++;
    }
    num[i] = '\0';
    
    return atof(num);
}

// Procesar JSON recibido
void procesar_json(const char* json) {
    char id_temp[50] = "";
    float temp = 0, hum = 0, dist = 0;
    int id_ok = 0, temp_ok = 0, hum_ok = 0, dist_ok = 0;
    
    printf("\nProcesando: %s\n", json);
    
    // Buscar cada clave
    char* valor = buscar_valor(json, "ID");
    if (valor) {
        extraer_string(valor, id_temp);
        if (id_temp[0] != '\0') id_ok = 1;
    }
    
    valor = buscar_valor(json, "Temperatura");
    if (valor) {
        temp = extraer_numero(valor);
        temp_ok = 1;
    }
    
    valor = buscar_valor(json, "Humedad");
    if (valor) {
        hum = extraer_numero(valor);
        hum_ok = 1;
    }
    
    valor = buscar_valor(json, "Distancia");
    if (valor) {
        dist = extraer_numero(valor);
        dist_ok = 1;
    }
    
    // Verificar si todos están presentes
    if (id_ok && temp_ok && hum_ok && dist_ok) {
        // Guardar en variables globales
        strcpy(ultimo_id, id_temp);
        ultima_temp = temp;
        ultima_hum = hum;
        ultima_dist = dist;
        
        // Mostrar resultado
        printf("\n================================\n");
        printf("DATOS VÁLIDOS:\n");
        printf("================================\n");
        printf("ID: %s\n", ultimo_id);
        printf("Temperatura: %.2f\n", ultima_temp);
        printf("Humedad: %.2f\n", ultima_hum);
        printf("Distancia: %.2f\n", ultima_dist);
        printf("================================\n\n");
    } else {
        printf("\nERROR: JSON inválido - Faltan datos\n");
    }
}

void app_main(void) {
    // Configurar UART
    uart_config_t uart_config = {
        .baud_rate = 115200,
        .data_bits = UART_DATA_8_BITS,
        .parity = UART_PARITY_DISABLE,
        .stop_bits = UART_STOP_BITS_1,
    };
    
    uart_param_config(UART_NUM_0, &uart_config);
    uart_driver_install(UART_NUM_0, BUF_SIZE * 2, 0, 0, NULL, 0);
    
    printf("\n\n========================================\n");
    printf("ANALIZADOR JSON - ESP32\n");
    printf("========================================\n");
    printf("Ejemplo: {\"ID\":\"sensor1\",\"Temperatura\":25.5,\"Humedad\":60,\"Distancia\":120}\n");
    printf("========================================\n\n");
    
    uint8_t* data = malloc(128);
    
    while (1) {
        int len = uart_read_bytes(UART_NUM_0, data, 127, 20 / portTICK_PERIOD_MS);
        
        if (len > 0) {
            for (int i = 0; i < len; i++) {
                char c = data[i];
                
                if (c == '\n' || c == '\r') {
                    if (pos_buffer > 0) {  // CAMBIADO index por pos_buffer
                        buffer[pos_buffer] = '\0';
                        procesar_json(buffer);
                        pos_buffer = 0;  // CAMBIADO index por pos_buffer
                        memset(buffer, 0, sizeof(buffer));
                        printf("\n> ");
                    }
                }
                else if (pos_buffer < 250 && c >= 32 && c <= 126) {  // CAMBIADO index por pos_buffer
                    printf("%c", c);
                    buffer[pos_buffer++] = c;  // CAMBIADO index por pos_buffer
                }
            }
        }
        
        vTaskDelay(10 / portTICK_PERIOD_MS);
    }
    
    free(data);
}
