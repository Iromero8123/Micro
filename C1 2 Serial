//Cuadrado de número entero//
#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <stdlib.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "driver/uart.h"
#include "esp_log.h"

#define BUF_SIZE 1024
#define RX_BUF_SIZE 64
#define UART_NUM UART_NUM_0

static const char *TAG = "CUADRADO";
static char rx_buffer[RX_BUF_SIZE];
static int rx_index = 0;

// Función para calcular cuadrado sumando números impares
int calcular_cuadrado_impares(int n) {
    int suma = 0;
    int impar = 1;
    
    printf("\nCalculando %d^2 = ", n);
    
    for (int i = 0; i < n; i++) {
        suma += impar;
        
        if (i > 0) {
            printf(" + ");
        }
        printf("%d", impar);
        
        impar += 2;
    }
    
    printf(" = %d\n", suma);
    return suma;
}

// Validar si es un número entero positivo válido
int es_numero_valido(const char *str) {
    int len = strlen(str);
    
    // Verificar que no esté vacío
    if (len == 0) {
        return 0;
    }
    
    // Verificar que todos los caracteres sean dígitos
    for (int i = 0; i < len; i++) {
        if (!isdigit((unsigned char)str[i])) {
            ESP_LOGD(TAG, "Carácter no dígito encontrado: %c", str[i]);
            return 0;
        }
    }
    
    // Verificar que no sea cero
    if (len == 1 && str[0] == '0') {
        ESP_LOGD(TAG, "Número cero detectado");
        return 0;
    }
    
    return 1;
}

// Procesar el número recibido
void procesar_numero(const char *dato) {
    printf("\n=================================\n");
    printf("Procesando: '%s'\n", dato);
    printf("=================================\n");
    
    // Validar el número
    if (!es_numero_valido(dato)) {
        ESP_LOGW(TAG, "Número inválido recibido: %s", dato);
        printf("ERROR: '%s' no es un número válido.\n", dato);
        printf("Solo se aceptan números enteros positivos mayores a cero.\n");
        printf("=================================\n\n");
        printf("Ingrese un número: ");
        fflush(stdout);
        return;
    }
    
    // Convertir a entero
    int numero = atoi(dato);
    
    // Verificación adicional de seguridad
    if (numero <= 0) {
        ESP_LOGW(TAG, "Número menor o igual a cero: %d", numero);
        printf("ERROR: El número debe ser mayor a cero.\n");
        printf("=================================\n\n");
        printf("Ingrese un número: ");
        fflush(stdout);
        return;
    }
    
    ESP_LOGI(TAG, "Calculando cuadrado de %d", numero);
    
    // Calcular el cuadrado usando el método de números impares
    int resultado = calcular_cuadrado_impares(numero);
    
    // Mostrar resultados
    printf("\nRESULTADO:\n");
    printf("  El cuadrado de %d es: %d\n", numero, resultado);
    printf("  Verificación: %d × %d = %d\n", numero, numero, numero * numero);
    printf("=================================\n\n");
    
    ESP_LOGI(TAG, "Cálculo completado exitosamente");
    
    // Solicitar siguiente número
    printf("Ingrese otro número: ");
    fflush(stdout);
}

// Inicializar UART
void uart_init(void) {
    const uart_config_t uart_config = {
        .baud_rate = 115200,
        .data_bits = UART_DATA_8_BITS,
        .parity = UART_PARITY_DISABLE,
        .stop_bits = UART_STOP_BITS_1,
        .flow_ctrl = UART_HW_FLOWCTRL_DISABLE,
        .source_clk = UART_SCLK_APB,
    };
    
    // Configurar parámetros UART
    ESP_ERROR_CHECK(uart_param_config(UART_NUM, &uart_config));
    
    // Configurar pines UART (TX: GPIO1, RX: GPIO3 para ESP32)
    ESP_ERROR_CHECK(uart_set_pin(UART_NUM, 1, 3, UART_PIN_NO_CHANGE, UART_PIN_NO_CHANGE));
    
    // Instalar driver UART
    ESP_ERROR_CHECK(uart_driver_install(UART_NUM, BUF_SIZE * 2, 0, 0, NULL, 0));
    
    ESP_LOGI(TAG, "UART inicializado correctamente a 115200 baudios");
}

// Función para limpiar el buffer
void limpiar_buffer(void) {
    memset(rx_buffer, 0, sizeof(rx_buffer));
    rx_index = 0;
}

// Mostrar mensaje de bienvenida
void mostrar_bienvenida(void) {
    printf("\n\n");
    printf("╔════════════════════════════════════════╗\n");
    printf("║     CALCULADORA DE CUADRADOS - ESP32   ║\n");
    printf("╠════════════════════════════════════════╣\n");
    printf("║ Método: Suma de N números impares      ║\n");
    printf("║                                         ║\n");
    printf("║ Ejemplo: 7² = 1+3+5+7+9+11+13 = 49     ║\n");
    printf("╠════════════════════════════════════════╣\n");
    printf("║ Instrucciones:                          ║\n");
    printf("║ • Ingrese un número entero POSITIVO    ║\n");
    printf("║ • Presione ENTER para calcular         ║\n");
    printf("║ • Los datos inválidos serán ignorados  ║\n");
    printf("║ • Ctrl+C para salir                    ║\n");
    printf("╚════════════════════════════════════════╝\n\n");
    printf("Ingrese un número: ");
    fflush(stdout);
}

void app_main(void) {
    // Inicializar logging
    esp_log_level_set(TAG, ESP_LOG_INFO);
    
    // Inicializar UART
    uart_init();
    
    // Mostrar mensaje de bienvenida
    mostrar_bienvenida();
    
    // Limpiar buffer
    limpiar_buffer();
    
    // Buffer temporal para lectura UART
    uint8_t *data = (uint8_t *)malloc(BUF_SIZE);
    if (data == NULL) {
        ESP_LOGE(TAG, "Error al asignar memoria");
        return;
    }
    
    while (1) {
        // Leer datos del UART
        int length = uart_read_bytes(UART_NUM, data, BUF_SIZE - 1, 20 / portTICK_PERIOD_MS);
        
        if (length > 0) {
            data[length] = '\0';
            
            // Procesar cada carácter recibido
            for (int i = 0; i < length; i++) {
                char c = (char)data[i];
                
                // Si es ENTER o nueva línea
                if (c == '\n' || c == '\r') {
                    if (rx_index > 0) {
                        rx_buffer[rx_index] = '\0';
                        
                        // Procesar el número
                        procesar_numero(rx_buffer);
                        
                        // Limpiar buffer para el siguiente número
                        limpiar_buffer();
                    }
                }
                // Si hay espacio en el buffer y es un carácter imprimible
                else if (rx_index < RX_BUF_SIZE - 1 && isprint((unsigned char)c)) {
                    // Echo del carácter (mostrar lo que se escribe)
                    printf("%c", c);
                    fflush(stdout);
                    
                    // Guardar en buffer
                    rx_buffer[rx_index++] = c;
                }
                // Si el buffer está lleno
                else if (rx_index >= RX_BUF_SIZE - 1) {
                    printf("\nERROR: Número demasiado largo. Reiniciando...\n");
                    limpiar_buffer();
                    printf("Ingrese un número: ");
                    fflush(stdout);
                }
            }
        }
        
        // Pequeña pausa para no saturar el CPU
        vTaskDelay(pdMS_TO_TICKS(10));
    }
    
    free(data);
}
